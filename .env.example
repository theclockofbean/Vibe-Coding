# ============================================================
# Application
# ============================================================
APP_NAME="AI Knowledge Agent Platform"
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
API_V1_PREFIX=/api/v1

# ============================================================
# Project paths
# ============================================================
PROJECT_ROOT=D:/Projects/ai-knowledge-agent-platform
DATA_DIR=D:/Projects/ai-knowledge-agent-platform/data
UPLOAD_DIR=D:/Projects/ai-knowledge-agent-platform/data/uploads
PARSED_DATA_DIR=D:/Projects/ai-knowledge-agent-platform/data/parsed
EVALUATION_DATA_DIR=D:/Projects/ai-knowledge-agent-platform/data/evaluation
REPORT_DIR=D:/Projects/ai-knowledge-agent-platform/data/reports
KNOWLEDGE_DIR=D:/Projects/ai-knowledge-agent-platform/knowledge
LOG_DIR=D:/Projects/ai-knowledge-agent-platform/logs
BACKUP_DIR=D:/Projects/ai-knowledge-agent-platform/backups

# ============================================================
# PostgreSQL
# ai_knowledge_agent and ai_kb_app are not created yet
# ============================================================
DATABASE_DRIVER=postgresql+psycopg
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=ai_knowledge_agent
DATABASE_USER=ai_kb_app
DATABASE_PASSWORD=
DATABASE_CLIENT_ENCODING=UTF8
DATABASE_SSLMODE=disable
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30

# ============================================================
# Qdrant
# Current server version: 1.18.0
# Collections are not created yet
# ============================================================
QDRANT_HOST=127.0.0.1
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_USE_HTTPS=false
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=10
QDRANT_PREFER_GRPC=false
QDRANT_COLLECTION_QUALITY=
QDRANT_COLLECTION_LOGISTICS=

# ============================================================
# Large Language Model
# Provider and model are not selected yet
# ============================================================
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.2

# ============================================================
# Embedding
# Model and vector dimension are not selected yet
# ============================================================
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=
EMBEDDING_BATCH_SIZE=32

# ============================================================
# Reranker
# ============================================================
RERANKER_PROVIDER=
RERANKER_API_KEY=
RERANKER_BASE_URL=
RERANKER_MODEL=
RERANKER_TOP_N=5

# ============================================================
# Retrieval
# ============================================================
RETRIEVAL_VECTOR_TOP_K=10
RETRIEVAL_KEYWORD_TOP_K=10
RETRIEVAL_FINAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.60
RETRIEVAL_RRF_K=60

# ============================================================
# Agent confidence and risk control
# ============================================================
INTENT_HIGH_CONFIDENCE_THRESHOLD=0.85
INTENT_LOW_CONFIDENCE_THRESHOLD=0.60
HUMAN_HANDOFF_ENABLED=true
PRICE_AUTO_REPLY_ENABLED=false
COMPLAINT_AUTO_REPLY_ENABLED=false
REQUIRE_SOURCE_REFERENCE=true

# ============================================================
# Channel switches
# P1 currently enables local debugging only
# ============================================================
CHANNEL_LOCAL_DEBUG_ENABLED=true
CHANNEL_WECHAT_ENABLED=false
CHANNEL_TAOBAO_ENABLED=false
CHANNEL_ALIBABA_IM_ENABLED=false

# ============================================================
# Frontend and CORS
# ============================================================
FRONTEND_URL=http://127.0.0.1:5173
CORS_ORIGINS=["[http://127.0.0.1:5173","http://localhost:5173](http://127.0.0.1:5173%22,%22http://localhost:5173)"]

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ============================================================
# Security
# Real value must only be stored in .env
# ============================================================
APP_SECRET_KEY=
