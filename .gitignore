# ============================================================
# Environment and secrets
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.class
*.so
.Python
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ============================================================
# Node.js and frontend
# ============================================================
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================================
# Runtime logs
# ============================================================
logs/**
!logs/.gitkeep
!logs/**/.gitkeep

# ============================================================
# Backups
# ============================================================
backups/**
!backups/.gitkeep
!backups/**/.gitkeep

# ============================================================
# Uploaded and generated data
# ============================================================
data/uploads/**
data/parsed/**
data/reports/**
!data/uploads/**/.gitkeep
!data/parsed/**/.gitkeep
!data/reports/**/.gitkeep

# Keep evaluation sets and sanitized samples versioned
!data/evaluation/**
!data/samples/**

# ============================================================
# Private business knowledge
# ============================================================
knowledge/structured/**/*.json
knowledge/vectorized/**/*.json
knowledge/versions/history/**

# Allow documentation and empty-directory placeholders
!knowledge/**/.gitkeep
!knowledge/**/README.md

# ============================================================
# Database and local service files
# ============================================================
*.db
*.sqlite
*.sqlite3
*.dump
*.backup
*.sql.gz

# Qdrant runtime data must remain in Docker Volume
infra/qdrant/storage/

# ============================================================
# IDE and operating system
# ============================================================
.vscode/
.idea/
*.code-workspace
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================
# Temporary files
# ============================================================
*.tmp
*.temp
*.swp
*.swo
*~
